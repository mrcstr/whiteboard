{
  "name": "whiteboard",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @whiteboard/db db:generate",
    "db:push": "pnpm --filter @whiteboard/db db:push",
    "db:studio": "pnpm --filter @whiteboard/db db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
    "@types/ws": "^8.5.10",
  },
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=20"
  }
}
